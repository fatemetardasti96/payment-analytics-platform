# Copy to .env and fill in values before running docker compose.

# Linux: set to your user id (id -u). macOS Docker Desktop can leave at 50000.
AIRFLOW_UID=50000

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# AWS credentials (base account; ingestion assumes role below)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1

# S3 / IAM (defaults match terraform outputs)
S3_BUCKET=demo-payment-bucket-2026
AWS_ROLE_ARN=arn:aws:iam::856611477482:role/payments-s3-role

# Airflow UI login (created on first init)
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
